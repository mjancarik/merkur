{
  "name": "@merkur/plugin-validation",
  "version": "1.0.1",
  "description": "Merkur plugin for schema validation (props and for future more). Library-agnostic - works with @esmj/schema, zod, and other schema libraries.",
  "main": "lib/index",
  "module": "lib/index",
  "types": "./types.d.ts",
  "unpkg": "lib/index.umd.js",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./types.d.ts",
      "import": "./lib/index.mjs",
      "require": "./lib/index.cjs"
    },
    "./lib/index.es9.mjs": "./lib/index.es9.mjs",
    "./lib/index.es9.cjs": "./lib/index.es9.cjs"
  },
  "browser": {
    "./lib/index.js": "./lib/index.js",
    "./lib/index.cjs": "./lib/index.cjs",
    "./lib/index.mjs": "./lib/index.mjs",
    "./lib/index.es9.mjs": "./lib/index.es9.mjs"
  },
  "scripts": {
    "test": "jest --no-watchman -c ./jest.config.js",
    "test:es:version": "es-check es11 ./lib/index.mjs --module && es-check es9 ./lib/index.es9.mjs --module && es-check es9 ./lib/index.es9.cjs --module",
    "build": "rollup -c rollup.config.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mjancarik/merkur.git"
  },
  "keywords": [
    "merkur",
    "plugin",
    "validation",
    "schema",
    "props",
    "state",
    "zod",
    "esmj"
  ],
  "author": "Miroslav Jancarik",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/mjancarik/merkur/issues"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "homepage": "https://merkur.js.org/",
  "devDependencies": {
    "@esmj/schema": "^0.7.2",
    "@merkur/core": "^1.0.0",
    "@merkur/plugin-component": "^1.0.0"
  },
  "peerDependencies": {
    "@merkur/core": "*",
    "@merkur/plugin-component": "*"
  }
}
