<% if (widgetProperties?.slot?.headline?.html) { %>
  <div
    class="<%= (widgetProperties?.slot?.headline?.containerSelector ?? 'merkur-headline').replace('.', '') %>"
    data-merkur-slot="headline"
  >
    <%- widgetProperties?.slot?.headline?.html %>
  </div>
<% } %>
<div
  class="<%= (widgetProperties?.containerSelector ?? 'merkur-main').replace('.', '') %>"
  data-merkur-container="main"
>
  <%- html %>
</div>
