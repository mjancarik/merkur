<script src="<%= merkurConfig.devServer.origin %><%= merkurConfig.devServer.staticPath %>/merkur-integration.js"></script>

<script>
  window.__merkur_dev__ = window.__merkur_dev__ || {};
  window.__merkur_dev__.merkurConfig = <%- escapeToJSON(merkurConfig) %>;
  window.__merkur_dev__.assets = <%- escapeToJSON(assets) %>;
  window.__merkur_dev__.widgetProperties = <%- escapeToJSON(widgetProperties) %>;
  <%- devClient %>
</script>

<script>
  (function () {
    var merkurIntegration = window.Merkur && window.Merkur.Integration;

    if (!merkurIntegration || typeof merkurIntegration.loadAssets !== 'function') {
      console.error(
        'Merkur integration is not available in the global scope. Make sure @merkur/integration package is installed.',
      );
      return;
    }

    merkurIntegration.loadAssets(window.__merkur_dev__.assets);
  })();
</script>
