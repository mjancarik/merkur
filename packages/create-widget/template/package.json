  "scripts": {
    "test": "npm run test:all",
    "test:unit": "cross-env TEST_GROUP='unit' merkur test",
    "test:integration": "cross-env TEST_GROUP='integration' merkur test",
    "test:all": "npm run build && cross-env TEST_GROUP='all' merkur test",
