    "@merkur/plugin-component": "1.0.3",
    "@merkur/plugin-error": "1.0.3",
    "@merkur/plugin-event-emitter": "1.0.3",
    "compression": "^1.7.4",
    "config": "^4.4.0",
    "cors": "^2.8.5",
    "cross-env": "^10.0.0",
    "express": "^5.2.0",
    "express-static-gzip": "^3.0.0",
    "helmet": "^8.0.0",
    "morgan": "^1.10.0"
