{
  "name": "merkur-monorepo",
  "description": "Merkur is library for creating micro frontend with server side rendering. ",
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@babel/eslint-parser": "^7.28.5",
    "@babel/plugin-transform-modules-commonjs": "^7.27.1",
    "@babel/preset-env": "^7.28.5",
    "@changesets/cli": "^2.26.2",
    "@rollup/plugin-babel": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-run": "^3.1.0",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^24.9.1",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "coveralls": "^3.1.1",
    "es-check": "^9.4.4",
    "eslint": "8.57.0",
    "eslint-config-last": "^0.0.5",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jasmine": "^4.2.2",
    "eslint-plugin-jest": "^28.9.0",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^16.2.6",
    "turbo": "^2.4.4",
    "prettier": "^3.6.2",
    "rollup": "^4.52.5",
    "to-mock": "^1.6.2",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "changeset": "changeset add",
    "postinstall": "npm run build",
    "build": "turbo build",
    "test": "turbo run test",
    "test:es:version": "turbo run test:es:version",
    "test:release": "utils/CIRelease.sh",
    "lint:cmd": "eslint -c ./.eslintrc.js --ignore-path ./.prettierignore  --no-eslintrc",
    "lint": "npm run lint:cmd -- './**/*.{mjs,cjs,js,jsx}'",
    "lint:fix": "npm run lint -- --fix",
    "commit": "echo 'This command has been replaced with \"npm run changeset\"'",
    "release": "npm run release:check && npm run release:versions && npm run release:prepare && npm run release:push",
    "release:versions": "changeset status --verbose",
    "release:check": "test $(git branch --show-current) != 'master' && echo 'Switch to master branch, please.' && exit 1 || test \"`git status . --porcelain`\" && echo 'Uncommitted changes found. Aborting release.' && exit 1 || exit 0",
    "release:prepare": "changeset version && npm i --package-lock-only --ignore-scripts",
    "release:push": "git add . && git commit -m 'Publish' && changeset tag && git push --follow-tags",
    "release:publish": "changeset publish --no-git-tag",
    "prepare": "husky"
  },
  "author": "Miroslav Jancarik <miroslav.jancarik@firma.seznam.cz>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mjancarik/merkur.git"
  },
  "bugs": {
    "url": "https://github.com/mjancarik/merkur/issues"
  },
  "lint-staged": {
    "**/*.{js,jsx}": "npm run lint:cmd"
  },
  "workspaces": [
    "packages/*"
  ],
  "packageManager": "npm@11.10.0"
}
